APP_NAME=Secure Service Catalog
APP_ENV=development
SECRET_KEY=replace-with-long-random-value
DATABASE_URL=postgresql+psycopg://catalog:catalog@db:5432/catalog

SESSION_COOKIE_NAME=catalog_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
AUTH_MODE=keycloak

OIDC_TEMP_COOKIE_NAME=oidc_login
OIDC_TEMP_COOKIE_MAX_AGE_SECONDS=300

KEYCLOAK_ISSUER_URL=https://keycloak.example.internal/realms/company
KEYCLOAK_CLIENT_ID=catalog
KEYCLOAK_CLIENT_SECRET=replace-with-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:8000/
KEYCLOAK_SCOPES=openid profile email groups
KEYCLOAK_GROUPS_CLAIM=groups
KEYCLOAK_GROUPS_PREFIX=/AD/
KEYCLOAK_ROLES_CLIENT_ID=catalog

DASHY_CONFIG_PATH=/app/data/dashy.yaml

TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0,::1,host.docker.internal
AUDIT_ENABLED=true
LOG_LEVEL=INFO

POSTGRES_DB=catalog
POSTGRES_USER=catalog
POSTGRES_PASSWORD=catalog
